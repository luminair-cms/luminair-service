{
  "type": "collection",
  "info": {
    "title": "Brands",
    "singularName": "brand",
    "pluralName": "brands",
    "description": "Brands of partners"
  },
  "options": {
    "draftAndPublish": true,
    "localizations": ["en", "ro"]
  },
  "attributes": {
    "uid": {
      "type": "uid",
      "unique": true,
      "required": true,
      "constraints": [
        { "minimalLength": 4 },
        { "maximalLength": 10 }
      ]
    },
    "name": {
      "type": "text",
      "required": true,
      "localized": true
    },
    "partners": {
      "relation": "belongsToMany",
      "target": "partners"
    }
  }
}
