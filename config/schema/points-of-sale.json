{
  "type": "collection",
  "info": {
    "title": "Points of sale",
    "singularName": "point-of-sale",
    "pluralName": "points-of-sale",
    "description": "Point of sale (concrete address)"
  },
  "options": {
    "draftAndPublish": true,
    "localizations": ["en", "ro", "ru"]
  },
  "attributes": {
    "title": {
      "type": "text"
    },
    "location": {
      "type": "text",
      "required": true,
      "localized": true
    },
    "latitude": {
      "type": {
        "decimal": {
          "precision": 10,
          "scale": 8
        }
      },
      "required": true
    },
    "longitude": {
      "type": {
        "decimal": {
          "precision": 10,
          "scale": 8
        }
      },
      "required": true
    },
    "partner": {
      "relation": "belongsToOne",
      "target": "partners"
    }
  }
}