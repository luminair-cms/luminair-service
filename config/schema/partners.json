{
  "type": "collection",
  "info": {
    "title": "Partners",
    "singularName": "partner",
    "pluralName": "partners",
    "description": "Partners with unique IDNO and Legal Entity"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "idno": {
      "type": "text",
      "unique": true,
      "required": true,
      "constraints": [
        { "pattern": "^[0-9]{13}$" }
      ]
    },
    "legal_entity": {
      "type": "text",
      "unique": true,
      "required": true
    },
    "brands": {
      "relation": "hasMany",
      "target": "brands"
    },
    "category": {
      "relation": "hasOne",
      "target": "partner-categories"
    },
    "points-of-sale": {
      "relation": "hasMany",
      "target": "points-of-sale"
    }
  }
}